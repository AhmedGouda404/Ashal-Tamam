{
  "version": 2,
  "builds": [
    { "src": "sharepoint.js", "use": "@vercel/node" },
    { "src": "Public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { 
      "src": "/api/sharepoint", 
      "dest": "/sharepoint.js" 
    },
    { 
      "src": "/(.*)", 
      "dest": "/Public/$1" 
    }
  ]
}

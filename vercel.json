{
  "version": 2,
  "builds": [
    {
      "src": "api/sharepoint.js",
      "use": "@vercel/node"
    },
    {
      "src": "Public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/sharepoint",
      "dest": "api/sharepoint.js"
    },
    {
      "src": "/(.*)",
      "dest": "Public/$1"
    }
  ]
}
